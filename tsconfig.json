{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"], 
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"], // <- novo TS 6 obrigatório
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"], // Padrão GLOB
  "exclude": ["node_modules", "dist"]
}